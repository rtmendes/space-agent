{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "checkJs": false,
    "lib": [
      "ES2023",
      "DOM"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "/mod/*": [
        "app/L0/_all/mod/*"
      ]
    },
    "target": "ES2022"
  },
  "exclude": [
    "node_modules",
    "app/L1",
    "app/L2"
  ],
  "include": [
    "space.js",
    "commands/**/*.js",
    "server/**/*.js",
    "packaging/**/*.js",
    "app/**/*.js",
    "app/**/*.d.ts"
  ],
  "typeAcquisition": {
    "include": [
      "node"
    ]
  }
}
